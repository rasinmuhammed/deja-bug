{
  "name": "deja-bug",
  "displayName": "Deja-Bug",
  "description": "Your AI debugging journal that learns from YOUR bugs. Capture errors, analyze with local AI, detect patterns, and become a better developer—100% private.",
  "version": "1.0.0",
  "publisher": "muhammedrasin",
  "icon": "assets/icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Machine Learning",
    "Other",
    "Programming Languages",
    "Snippets"
  ],
  "keywords": [
    "debugging",
    "ai",
    "learning",
    "patterns",
    "errors",
    "llm",
    "cursor",
    "copilot",
    "ollama",
    "terminal",
    "bug-tracking"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/muhammedrasin/deja-bug"
  },
  "bugs": {
    "url": "https://github.com/muhammedrasin/deja-bug/issues"
  },
  "homepage": "https://github.com/muhammedrasin/deja-bug#readme",
  "license": "MIT",
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "enabledApiProposals": [
    "terminalDataWriteEvent"
  ],
  "contributes": {
    "commands": [
      {
        "command": "deja-bug.manualCapture",
        "title": "Deja-Bug: Force Capture Current Bug",
        "icon": "$(bug)"
      },
      {
        "command": "deja-bug.showTimeline",
        "title": "Deja-Bug: Show Timeline",
        "icon": "$(history)"
      },
      {
        "command": "deja-bug.showPatterns",
        "title": "Deja-Bug: Show Debugging Patterns",
        "icon": "$(graph)"
      },
      {
        "command": "deja-bug.showInsights",
        "title": "Deja-Bug: Generate Monthly Insights",
        "icon": "$(lightbulb)"
      },
      {
        "command": "deja-bug.searchBugs",
        "title": "Deja-Bug: Search Past Bugs",
        "icon": "$(search)"
      },
      {
        "command": "deja-bug.restartServer",
        "title": "Deja-Bug: Restart MCP Server"
      }
    ],
    "keybindings": [
      {
        "command": "deja-bug.manualCapture",
        "key": "cmd+shift+d",
        "mac": "cmd+shift+d",
        "win": "ctrl+shift+d",
        "linux": "ctrl+shift+d"
      }
    ],
    "configuration": {
      "title": "Deja-Bug",
      "properties": {
        "deja-bug.autoCapture": {
          "type": "boolean",
          "default": true,
          "description": "Automatically capture terminal errors"
        },
        "deja-bug.captureMode": {
          "type": "string",
          "enum": [
            "off",
            "manual",
            "smart",
            "everything"
          ],
          "default": "smart",
          "description": "Capture mode: off (disabled), manual (only via command), smart (time-based filter), everything (all errors)"
        },
        "deja-bug.minResolutionTime": {
          "type": "number",
          "default": 120,
          "minimum": 0,
          "description": "Minimum time (in seconds) between error and fix to auto-capture. Filters out quick syntax fixes."
        },
        "deja-bug.confidenceThreshold": {
          "type": "number",
          "default": 0.5,
          "minimum": 0,
          "maximum": 1,
          "description": "Minimum confidence score (0-1) to auto-capture a bug"
        },
        "deja-bug.bufferSize": {
          "type": "number",
          "default": 200,
          "description": "Number of terminal lines to buffer for context"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run package",
    "compile": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap",
    "watch": "pnpm run compile -- --watch",
    "package": "pnpm run compile -- --minify",
    "test": "vitest",
    "lint": "eslint src --ext ts",
    "format": "prettier --write 'src/**/*.ts'"
  },
  "devDependencies": {
    "@types/node": "^20.11.5",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "esbuild": "^0.20.0",
    "eslint": "^8.56.0",
    "prettier": "^3.2.4",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  },
  "dependencies": {}
}